# Backend Environment Variables Example

# The port the server will run on (Default: 5000)
PORT=5000

# PostgreSQL connection string
# Standard format: postgres://user:password@host:port/database
# Provided by Railway, Render, or Supabase
DATABASE_URL=postgres://user:password@localhost:5432/microfast_inventory

# Secret for JWT signing
JWT_SECRET=your_super_secret_key_change_this_for_production

# Frontend URL (for CORS security if needed)
# FRONTEND_URL=https://microfast-inventory.vercel.app

# Environment (development or production)
NODE_ENV=production
